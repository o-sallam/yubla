{
  "version": 2,
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "vite",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "includeFiles": "{node_modules/sql.js/dist/*.wasm,yubla.sqlite}"
    }
  },
  "env": {
    "NODE_ENV": "production"
  }
}
